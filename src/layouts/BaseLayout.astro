---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AI Engineering Brief',
  description = 'A twice-weekly briefing on practical AI engineering.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f5ef" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111416" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      const storedTheme = localStorage.getItem('theme');
      if (storedTheme === 'light' || storedTheme === 'dark') {
        document.documentElement.dataset.theme = storedTheme;
      }
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="AI Engineering Brief home">
        <span>AI Engineering Brief</span>
      </a>
      <button class="theme-toggle" type="button" aria-label="Toggle color mode">
        <span aria-hidden="true">◐</span>
      </button>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Published Wednesday and Sunday from Hermes AI.</p>
    </footer>
    <script is:inline>
      const button = document.querySelector('.theme-toggle');
      const root = document.documentElement;
      button?.addEventListener('click', () => {
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
